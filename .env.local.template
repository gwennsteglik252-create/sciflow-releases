# Mac 代码公证（Notarization）凭据模板
# 请将此文件复制重命名为 `.env.local`，并填入你的真实凭据。
# 该文件已经被 .gitignore 忽略，绝不会被传到代码库中。

# 你的 Apple ID 邮箱账号
APPLE_ID=your-email@apple.com

# 你的 App 专用密码 (注意: 不是你的 Apple ID 登录密码，去 appleid.apple.com 生成)
APPLE_APP_SPECIFIC_PASSWORD=abcd-efgh-ijkl-mnop

# 你的 Apple 开发者 Team ID (例如 XXXXXX1234，在 Apple 开发者后台获取)
APPLE_TEAM_ID=XXXXXXXXXX
