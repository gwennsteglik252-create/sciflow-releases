# Gemini API Key（任选其一即可，优先 VITE_GEMINI_API_KEY）
# 用于文献分析、写作润色、流程图、DOE 等 AI 能力；项目通过 import.meta.env.VITE_GEMINI_API_KEY 读取
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# 或使用以下变量名（vite.config 会注入为 VITE_GEMINI_API_KEY）：
# API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Gemini AI Studio Builder 预览模式（可选）：设为 true 时 useMockData() 为 true，组件使用 Mock 数据
# VITE_BUILDER_PREVIEW=false
