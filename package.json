{
  "name": "sciflow-pro",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:build": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --external:electron --external:electron-updater --format=cjs --outdir=electron --out-extension:.js=.cjs",
    "electron": "npm run electron:build && concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dist": "npm run build && npm run electron:build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.99.0",
    "@types/three": "^0.183.1",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.34.3",
    "html-to-image": "^1.11.11",
    "jspdf": "^2.5.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.9",
    "postprocessing": "^6.38.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "recharts": "^2.15.0",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "three": "^0.183.1",
    "utif": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/utif": "^3.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.27.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.sciflow.pro",
    "afterPack": "./scripts/afterPack.cjs",
    "productName": "SciFlow Pro",
    "artifactName": "SciFlow-Pro-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "artifactName": "SciFlow-Pro-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.icns",
      "identity": null
    },
    "publish": {
      "provider": "github",
      "owner": "gwennsteglik252-create",
      "repo": "sciflow-releases"
    }
  }
}
