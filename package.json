{
  "name": "sciflow-pro",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:build": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --external:electron --external:electron-updater --format=cjs --outdir=electron --out-extension:.js=.cjs",
    "electron": "npm run electron:build && concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dist": "ELECTRON_BUILD=true npm run build && npm run electron:build && electron-builder",
    "deploy:web": "DEPLOY_BASE=/sciflow-releases/ npm run build:web && npx -y gh-pages -d dist",
    "build:mobile": "MOBILE_BUILD=true vite build",
    "cap:sync": "npx cap sync android && npx cap sync ios",
    "cap:build:apk": "./scripts/build-apk.sh",
    "cap:build:ios": "./scripts/build-ios.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@google/genai": "^1.34.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.99.0",
    "@tiptap/extension-bubble-menu": "^3.20.4",
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-font-family": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-subscript": "^3.20.4",
    "@tiptap/extension-superscript": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-text-align": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@types/three": "^0.183.1",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "elkjs": "^0.11.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.34.3",
    "html-to-image": "^1.11.11",
    "i18next": "^25.8.18",
    "jspdf": "^2.5.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.9",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^4.4.168",
    "plotly.js": "^3.4.0",
    "postprocessing": "^6.38.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "react-markdown": "^9.0.1",
    "react-plotly.js": "^2.6.0",
    "recharts": "^2.15.0",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "three": "^0.183.1",
    "tiptap-extension-pagination": "^2.1.4",
    "tiptap-pagination-breaks": "^1.0.3",
    "utif": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-plotly.js": "^2.6.4",
    "@types/utif": "^3.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.27.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^7.2.0",
    "workbox-window": "^7.4.0"
  },
  "build": {
    "appId": "com.sciflow.pro",
    "afterPack": "./scripts/afterPack.cjs",
    "productName": "SciFlow Pro",
    "artifactName": "SciFlow-Pro-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "artifactName": "SciFlow-Pro-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true
    },
    "publish": {
      "provider": "github",
      "owner": "gwennsteglik252-create",
      "repo": "sciflow-releases"
    }
  }
}
